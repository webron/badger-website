---
import Search from 'astro-pagefind/components/Search';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const nav = [
  {
    label: 'Getting Started',
    items: [
      { href: `/help/getting-started`, label: 'Quick start' },
      { href: `/help/getting-started#first-workout`, label: 'Your first workout' },
      { href: `/help/getting-started#importing`, label: 'Importing from another app' },
    ],
  },
  {
    label: 'Logging Workouts',
    items: [
      { href: `/help/logging`, label: 'Logging sets' },
      { href: `/help/logging#set-types`, label: 'Warmup & working sets' },
      { href: `/help/logging#rest-timer`, label: 'Rest timer' },
      { href: `/help/logging#supersets`, label: 'Supersets' },
    ],
  },
  {
    label: 'Exercises',
    items: [
      { href: `/help/exercises`, label: 'Exercise library' },
      { href: `/help/exercises#search-filter`, label: 'Search & filters' },
      { href: `/help/exercises#creating`, label: 'Creating exercises' },
      { href: `/help/exercises#types`, label: 'Exercise types' },
    ],
  },
  {
    label: 'Routines',
    items: [
      { href: `/help/routines`, label: 'Overview' },
      { href: `/help/routines#creating`, label: 'Creating routines' },
      { href: `/help/routines#predefined-sets`, label: 'Predefined sets' },
      { href: `/help/routines#starting`, label: 'Starting a routine workout' },
      { href: `/help/routines#programs`, label: 'Built-in programs' },
    ],
  },
  {
    label: 'Gyms & Equipment',
    items: [
      { href: `/help/gyms`, label: 'Managing gyms' },
      { href: `/help/gyms#machines`, label: 'Machines & attachments' },
      { href: `/help/gyms#grip-types`, label: 'Grip types' },
      { href: `/help/gyms#workout-context`, label: 'Gym context in workouts' },
    ],
  },
  {
    label: 'History',
    items: [
      { href: `/help/history`, label: 'Viewing history' },
      { href: `/help/history#views`, label: 'List & calendar views' },
      { href: `/help/history#filtering`, label: 'Filtering workouts' },
      { href: `/help/history#per-exercise`, label: 'Per-exercise history' },
    ],
  },
  {
    label: 'Progress',
    items: [
      { href: `/help/progress`, label: 'Exercise progress' },
      { href: `/help/progress#prs`, label: 'Personal records' },
      { href: `/help/progress#graphs`, label: 'Graphs & charts' },
      { href: `/help/progress#muscle-balance`, label: 'Muscle balance' },
    ],
  },
  {
    label: 'Tools',
    items: [
      { href: `/help/tools`, label: 'Plate calculator' },
      { href: `/help/tools#warmup-calc`, label: 'Warmup calculator' },
      { href: `/help/tools#deload`, label: 'Deload' },
    ],
  },
  {
    label: 'Settings & Data',
    items: [
      { href: `/help/settings`, label: 'Settings overview' },
      { href: `/help/settings#data`, label: 'Data & backup' },
      { href: `/help/settings#export`, label: 'Exporting data' },
      { href: `/help/settings#importing`, label: 'Importing history' },
      { href: `/help/phone-migration`, label: 'Moving to a new phone' },
    ],
  },
  {
    label: 'Reference',
    items: [
      { href: `/glossary`, label: 'Glossary' },
    ],
  },
  {
    label: 'Legal',
    items: [
      { href: `/legal/privacy`, label: 'Privacy policy' },
      { href: `/legal/terms`, label: 'Terms of service' },
    ],
  },
];
---

<aside id="help-sidebar">
  <!-- Search pinned at top — never scrolls away -->
  <div class="help-search-wrap">
    <Search id="help-search" uiOptions={{ showImages: false, showSubResults: false, excerptLength: 12, pageSize: 20 }} />
  </div>
  <!-- Nav: scrolls independently on desktop, collapsible on mobile -->
  <details id="help-nav-details" open>
    <summary class="help-nav-toggle">
      <span class="help-nav-toggle-label">Browse help topics</span>
      <svg class="help-nav-toggle-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </summary>
    <nav id="help-sidebar-nav">
    {nav.map(section => (
      <div style="margin-bottom:1.5rem;">
        <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin:0 0 0.5rem;padding-left:0.75rem;">
          {section.label}
        </p>
        <ul style="list-style:none;margin:0;padding:0;">
          {section.items.map(item => {
            const itemPath = item.href.split('#')[0];
            const active = currentPath === itemPath || currentPath === item.href;
            return (
              <li>
                <a
                  href={item.href}
                  style={`display:block;padding:0.3rem 0.75rem;font-size:0.875rem;border-radius:5px;text-decoration:none;${
                    active
                      ? 'color:var(--color-accent);background:var(--color-accent-dim);font-weight:600;'
                      : 'color:var(--text-secondary);'
                  }`}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
    </nav>
  </details>
</aside>

<style is:global>
  /* Pagefind UI theme — mapped to site CSS variables */
  #help-search {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--surface-alt);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: inherit;
  }

  /* Tighten result list spacing for the narrow sidebar */
  #help-search .pagefind-ui__results {
    position: absolute;
    z-index: 50;
    width: 220px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    max-height: 60vh;
    overflow-y: auto;
  }

  #help-search .pagefind-ui__result {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  #help-search .pagefind-ui__result:last-child {
    border-bottom: none;
  }

  #help-search .pagefind-ui__result-title {
    font-size: 0.8125rem;
  }

  #help-search .pagefind-ui__result-excerpt {
    font-size: 0.75rem;
  }

  /* Replace browser focus ring with accent glow */
  #help-search .pagefind-ui__search-input:focus {
    outline: none;
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px var(--color-accent-dim);
  }
</style>

<style>
  #help-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 1.5rem;
    max-height: calc(100vh - 3rem);
    display: flex;
    flex-direction: column;
  }

  .help-search-wrap {
    flex-shrink: 0;
    margin-bottom: 0.75rem;
  }

  /* details acts as a normal flex child — behaves as a plain block on desktop */
  #help-nav-details {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  #help-nav-details > summary {
    list-style: none;
    cursor: pointer;
  }
  #help-nav-details > summary::-webkit-details-marker {
    display: none;
  }

  #help-sidebar-nav {
    overflow-y: auto;
    flex: 1;
  }

  /* Desktop: hide the summary, keep the nav always visible.
     The inline script removes `open` on mobile — on desktop it stays open. */
  @media (min-width: 769px) {
    #help-nav-details > summary {
      display: none;
    }
  }

  /* Mobile: sidebar becomes a static, full-width block above content.
     Summary turns into a tappable "Browse help topics" bar. */
  @media (max-width: 768px) {
    #help-sidebar {
      width: 100%;
      position: static;
      max-height: none;
      margin-bottom: 1.5rem;
    }

    .help-nav-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text);
    }

    .help-nav-toggle-icon {
      transition: transform 0.15s ease;
    }

    #help-nav-details[open] .help-nav-toggle-icon {
      transform: rotate(180deg);
    }

    #help-sidebar-nav {
      margin-top: 0.5rem;
      padding: 0.5rem 0;
      max-height: 70vh;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
    }
  }
</style>

<script is:inline>
  (function () {
    // Default the mobile disclosure to closed; leave it open on desktop.
    const details = document.getElementById('help-nav-details');
    if (details && window.matchMedia('(max-width: 768px)').matches) {
      details.removeAttribute('open');
    }

    // Preserve nav scroll position across clicks.
    const KEY = 'help-sidebar-scroll';
    const nav = document.getElementById('help-sidebar-nav');
    if (!nav) return;

    const saved = sessionStorage.getItem(KEY);
    if (saved) nav.scrollTop = parseInt(saved, 10);

    nav.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        sessionStorage.setItem(KEY, nav.scrollTop);
      });
    });
  })();
</script>
