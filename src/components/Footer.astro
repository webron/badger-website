    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;">
      <a href={`/`} style="font-size:0.875rem;color:var(--text-muted);">Home</a>
      <a href={`/help`} style="font-size:0.875rem;color:var(--text-muted);">Help</a>
