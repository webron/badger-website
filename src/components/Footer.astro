---
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer style="border-top:1px solid var(--border);margin-top:5rem;padding:2rem 1.5rem;text-align:center;">
  <div style="max-width:1100px;margin:0 auto;display:flex;flex-direction:column;align-items:center;gap:0.75rem;">
    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;">
      <a href={`${b}/`} style="font-size:0.875rem;color:var(--text-muted);">Home</a>
      <a href={`${b}/help`} style="font-size:0.875rem;color:var(--text-muted);">Help</a>
      <a href={`${b}/glossary`} style="font-size:0.875rem;color:var(--text-muted);">Glossary</a>
    </div>
    <p style="font-size:0.8rem;color:var(--text-muted);margin:0;">
      &copy; {new Date().getUTCFullYear()} Badger. All rights reserved.
    </p>
  </div>
</footer>
