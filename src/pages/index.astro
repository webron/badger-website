---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Badger',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Android, iOS',
  url: 'https://badger.fit',
  downloadUrl: 'https://play.google.com/store/apps/details?id=fit.badger.app',
  description:
    'Badger is a workout and strength tracker for Android and iOS. Log sets, run your programs, and track what your training is actually doing.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<BaseLayout
  title="Badger"
  fullTitle="Badger - Workout & Strength Tracker for Android & iOS"
  description="Badger is a workout and strength tracker for Android and iOS. Log sets, run your programs, and track what your training is actually doing. Built for lifters who pay attention to the details."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(appJsonLd)} />

  <Header currentPath={Astro.url.pathname} />

  <!-- Hero -->
  <section style="max-width:1100px;margin:0 auto;padding:5rem 1.5rem 4rem;display:flex;flex-direction:column;align-items:center;text-align:center;gap:1.5rem;">
    <img src={`/assets/badger_logo_stacked.svg`} alt="Badger" width="120" style="display:block;" />

    <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:700;margin:0;line-height:1.15;color:var(--text);">
      A workout tracker for lifters who pay attention.
    </h1>

    <p style="font-size:1.1rem;color:var(--text-secondary);max-width:520px;margin:0;line-height:1.6;">
      Log sets, run your programs, and see what your training is actually doing. Built for lifters who pay attention to the details.
    </p>

    <div id="download" style="display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;align-items:center;margin-top:0.5rem;">
      <a
        href="https://play.google.com/store/apps/details?id=fit.badger.app"
        aria-label="Get it on Google Play"
        style="display:inline-flex;"
      >
        <img src={`/assets/badges/google-play-badge.png`} alt="Get it on Google Play" height="60" style="display:block;height:60px;width:auto;" />
      </a>
      <a
        href="https://testflight.apple.com/join/wqxnbujx"
        aria-label="Try the iOS beta on TestFlight"
        style="display:inline-flex;align-items:center;justify-content:center;width:155px;height:60px;text-decoration:none;box-sizing:border-box;"
      >
        <span style="display:inline-flex;align-items:center;justify-content:center;gap:0.4rem;width:135px;height:40px;background:#000;border:1px solid rgba(255,255,255,0.3);border-radius:6px;color:#fff;box-sizing:border-box;">
          <svg width="17" height="20" viewBox="0 0 384 512" fill="#fff" aria-hidden="true"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
          <span style="display:flex;flex-direction:column;line-height:1.05;text-align:left;">
            <span style="font-size:0.5rem;letter-spacing:0.3px;opacity:0.85;">TRY THE</span>
            <span style="font-size:0.9rem;font-weight:600;">iOS beta</span>
          </span>
        </span>
      </a>
    </div>
    <div style="display:flex;justify-content:center;margin-top:0.85rem;">
      <a
        href={`/help/getting-started`}
        style="display:inline-flex;align-items:center;gap:0.5rem;color:var(--text-secondary);font-weight:500;padding:0.5rem 0.75rem;text-decoration:none;font-size:0.95rem;"
      >
        Read the docs →
      </a>
    </div>
  </section>

  <!-- Screenshots -->
  <section style="max-width:1100px;margin:0 auto;padding:0 1.5rem 5rem;overflow:hidden;">
    <div style="display:flex;justify-content:center;align-items:flex-end;gap:1.5rem;flex-wrap:nowrap;">
      {[
        { src: '/assets/screenshots/badger-1-today.png', alt: 'Today screen showing active workout', scale: '0.88' },
        { src: '/assets/screenshots/badger-2-training.png', alt: 'Training screen with live set logging', scale: '1' },
        { src: '/assets/screenshots/badger-6-progress-exercise.png', alt: 'Progress screen with exercise graph and PRs', scale: '0.88' },
      ].map(s => (
        <div style={`flex:0 0 auto;width:clamp(160px,22vw,240px);transform:scale(${s.scale});transform-origin:bottom center;`}>
          <div style="border-radius:36px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.45);border:3px solid rgba(255,255,255,0.08);background:#111;">
            <img
              src={s.src}
              alt={s.alt}
              width="1080"
              height="2400"
              style="display:block;width:100%;height:auto;"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section style="max-width:1100px;margin:0 auto;padding:0 1.5rem 5rem;">
    <h2 style="font-size:1.5rem;font-weight:700;margin:0 0 2.5rem;color:var(--text);text-align:center;">What's in the app</h2>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
      {[
        {
          title: 'Detailed logging',
          body: 'Weight, reps, time, distance - whatever the exercise needs. Warmup sets, RPE, RIR, and tempo tracking included.',
        },
        {
          title: 'Rest timer',
          body: 'Auto-starts after each working set. Per-exercise defaults, per-session overrides, and sound or vibration alerts.',
        },
        {
          title: 'Routines & programs',
          body: 'Build your own programs or use one of the 7 built-in ones (StrongLifts, 5/3/1, PPL, and more). Supersets, scheduled days, and predefined sets included.',
        },
        {
          title: 'Progress tracking',
          body: 'Estimated 1RM, PR detection, 12+ graph types per exercise, 26-week activity heatmap, and weekly volume by muscle group.',
        },
        {
          title: 'Gym & equipment',
          body: 'Track which gym and machine you used for each exercise. Machine-scoped PRs, attachment defaults, and grip type tracking.',
        },
        {
          title: 'Plate calculator',
          body: 'Barbell, machine, and single-lever modes. Finds the best plate combination from your available plates automatically.',
        },
        {
          title: 'Planned vs. actual',
          body: 'When you finish a routine workout, the summary shows what you hit against what the routine asked for - set by set, with wins highlighted.',
        },
        {
          title: 'Bring your history',
          body: 'Import from FitNotes, Strong, or Hevy. Export to CSV or back up the full database anytime.',
        },
        {
          title: 'Deload detection',
          body: 'Optional automatic deload scheduling. Detects fatigue via time, RPE/RIR, or stalled performance, and reduces weights when you start your next session.',
        },
      ].map(f => (
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem;">
          <h3 style="font-size:1rem;font-weight:600;margin:0 0 0.5rem;color:var(--text);">{f.title}</h3>
          <p style="font-size:0.9rem;color:var(--text-secondary);margin:0;line-height:1.6;">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section style="max-width:1100px;margin:0 auto;padding:0 1.5rem 5rem;text-align:center;">
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:3rem 2rem;">
      <h2 style="font-size:1.5rem;font-weight:700;margin:0 0 0.75rem;color:var(--text);">Ready to start?</h2>
      <p style="color:var(--text-secondary);margin:0 0 1.5rem;max-width:400px;display:inline-block;line-height:1.6;">
        Badger is free on Google Play, with an iOS beta now open in TestFlight.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;align-items:center;">
        <a
          href="https://play.google.com/store/apps/details?id=fit.badger.app"
          aria-label="Get it on Google Play"
          style="display:inline-flex;"
        >
          <img src={`/assets/badges/google-play-badge.png`} alt="Get it on Google Play" height="60" style="display:block;height:60px;width:auto;" />
        </a>
        <a
          href="https://testflight.apple.com/join/wqxnbujx"
          aria-label="Try the iOS beta on TestFlight"
          style="display:inline-flex;align-items:center;justify-content:center;width:155px;height:60px;text-decoration:none;box-sizing:border-box;"
        >
          <span style="display:inline-flex;align-items:center;justify-content:center;gap:0.4rem;width:135px;height:40px;background:#000;border:1px solid rgba(255,255,255,0.3);border-radius:6px;color:#fff;box-sizing:border-box;">
            <svg width="17" height="20" viewBox="0 0 384 512" fill="#fff" aria-hidden="true"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
            <span style="display:flex;flex-direction:column;line-height:1.05;text-align:left;">
              <span style="font-size:0.5rem;letter-spacing:0.3px;opacity:0.85;">TRY THE</span>
              <span style="font-size:0.9rem;font-weight:600;">iOS beta</span>
            </span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
